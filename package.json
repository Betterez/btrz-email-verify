{
  "name": "btrz-email-verify",
  "version": "2.1.0",
  "description": "Verify emails using Quick Email Verifier and save into a blacklist in a mongodb database.",
  "main": "index.js",
  "scripts": {
    "start": "node ./index.js",
    "test:only": "node --test --test-concurrency=1 --test-only --test-force-exit test/*-tests.js",
    "test": "node --test --test-concurrency=1 --test-force-exit test/*-tests.js",
    "tdd": "node --test --watch --test-concurrency=1 --test-force-exit test/*-tests.js",
    "preversion": "npm test",
    "postversion": "git push origin master && git push --tags",
    "prepare": "git config core.hooksPath .githooks"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "btrz-simple-dao": "4.6.0",
    "bz-date": "2.2.0"
  },
  "devDependencies": {
    "chance": "1.1.13",
    "nock": "^14.0.16"
  }
}
